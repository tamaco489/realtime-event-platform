        "Definition": "# イベントの基本情報を表す型
type Event {
  event_id: String! # イベント固有 ID
  event_type: String! # イベント種別 (例: order.created)
  payload: String! # イベントペイロード (JSON 文字列)
  created_at: AWSTimestamp! # イベント発生日時 (Unix タイムスタンプ, 秒)
}

# publishEvent Mutation の入力型
input PublishEventInput {
  event_type: String! # イベント種別
  payload: String! # イベントペイロード (JSON 文字列)
}

type Mutation {
  # イベントを AppSync へ Publish し、Subscription に Push する
  publishEvent(input: PublishEventInput!): Event
}

type Subscription {
  # publishEvent Mutation が呼ばれたときにフロントエンドへリアルタイム Push する
  onEventReceived: Event @aws_subscribe(mutations: ["publishEvent"])
}

# AppSync は Query 型が必須のため placeholder を定義する
type Query {
  placeholder: String
}

schema {
  query: Query
  mutation: Mutation
  subscription: Subscription
}
